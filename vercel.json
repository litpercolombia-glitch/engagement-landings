{
  "rewrites": [
    { "source": "/tips-hotel", "destination": "/tips-hotel/index.html" },
    { "source": "/protector-guia", "destination": "/protector-guia/index.html" },
    { "source": "/cortinas-blackout", "destination": "/cortinas-blackout/index.html" },
    { "source": "/cobija-perfecta", "destination": "/cobija-perfecta/index.html" },
    { "source": "/suite-lujo", "destination": "/suite-lujo/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
